<html xmlns:t="http://tapestry.apache.org/schema/tapestry_5_4.xsd">
<head>
    <title>Employee Detail</title>
</head>
<body>

<t:Header/>
<h2 class="text-center">Employee Details</h2>
<br/>
<table class="table table-bordered">
    <thead class="table-header">
    <th>ID</th>
    <th>Name</th>
    <th>Age</th>
    <th>Address</th>
    <th>Gender</th>
    <th>Designation</th>
    <th>Dob</th>
    <t:if test="canEdit">
    <th>Action</th>
    </t:if>
    </thead>
    <tbody>
    <tr>
        <td>${employee.id}</td>
        <td>${employee.name}</td>
        <td>${employee.age}</td>
        <td>${employee.address}</td>
        <td>${employee.gender}</td>
        <td>${employee.designation}</td>
        <td>${employee.dob}</td>
        <t:if test="canEdit">
        <td>
            <t:pagelink page="EditEmployee" context="employee.id">
                Edit
            </t:pagelink>
        </td>
        </t:if>
    </tr>
    </tbody>
</table>
<t:if test="admin">
<t:pagelink page="EmployeeList">Back to List</t:pagelink>
</t:if>
</body>
</html>