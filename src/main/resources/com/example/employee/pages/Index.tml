<html xmlns:t="http://tapestry.apache.org/schema/tapestry_5_4.xsd" xmlns:p="tapestry:parameter">
<head>
    <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
</head>
<body>
<!--        <h1>Login</h1>-->
<!--         <t:form>-->
<!--         Username<t:textfield t:="userNameValue"/>-->
<!--         Password<t:textfield t:id="passValue"/>-->
<!--         </t:form>-->
<div class="container mt-5">
<div class="row justify-content-center">
    <t:Header/>
<div class="col-md-4">
    <h2 class="text-center mb-4">Employee Login</h2>
<t:form style="border:1px solid; padding:20px;">
    <div class="mb-3">
    <label>Username:</label>
    <t:textfield t:value="username"/>
    </div>
    <div class="mb-3">
    <label>Password:</label>
    <t:passwordfield t:value="password"/>
    </div>
    <t:submit value="Login"/>
</t:form >

<t:if test="error">
    <p style="color:red;">Invalid Username or Password</p>
</t:if>
</div>
</div>
</div>
    </body>
</html>