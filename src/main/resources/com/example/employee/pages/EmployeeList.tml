<html xmlns:t="http://tapestry.apache.org/schema/tapestry_5_4.xsd" xmlns:p="tapestry:parameter">
<head>
    <title>Employee List</title>
</head>
<body>
<t:header/>

<h2>Employee List</h2>
<t:grid source="employees" row="employee" add="prop:gridAddedColumns" exclude="fileName,password,role_id">
<!--    <p:dobHeader>-->
<!--        Date Of Birth-->
<!--    </p:dobHeader>-->
    <p:idCell>
        <t:pagelink page="EmployeeDetails" context="employee.id">${employee.id}</t:pagelink>
    </p:idCell>
    <p:actionCell>
        <t:if test="canView">

        <t:pagelink page="EmployeeView" context="employee.id">
            View
        </t:pagelink>
        </t:if>
    </p:actionCell>

</t:grid>
<t:if test="isBirthday">
    <t:WishBanner employee="birthdayEmployee"/>
</t:if>
<t:if test="canAdd">
<t:pagelink page="AddEmployee" >
    Add New Employee
</t:pagelink>
</t:if>
</body>
</html>