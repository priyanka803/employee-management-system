<!--    <t:column name="name" value="employee.name"/>-->
<!--    <t:column name="email" value="employee.email"/>-->

<!--    &lt;!&ndash; 🔹 View Column &ndash;&gt;-->
<!--    <t:column name="view">-->
<!--        <t:pagelink page="EmployeeDetail" context="employee.id">-->
<!--            View-->
<!--        </t:pagelink>-->
<!--    </t:column>-->

<!--</t:grid>-->
<t:pagelink page="AddEmployee" >
    Add New Employee
</t:pagelink>
</body>
</html>