<html xmlns:t="http://tapestry.apache.org/schema/tapestry_5_4.xsd" xmlns:p="tapestry:parameter">
<head>
    <title>Employee List</title>
</head>
<body>
<t:header/>
<h2>Employee List</h2>

<t:grid source="employees" row="employee" add="action" exclude="fileName">
<!--    <p:dobHeader>-->
<!--        Date Of Birth-->
<!--    </p:dobHeader>-->
    <p:idCell>
        <t:pagelink page="EmployeeDetails" context="employee.id">${employee.id}</t:pagelink>
    </p:idCell>
    <p:actionCell>
        <t:pagelink page="EmployeeView" context="employee.id">
            View
        </t:pagelink>
    </p:actionCell>

</t:grid>

<t:pagelink page="AddEmployee" >
    Add New Employee
</t:pagelink>
</body>
</html>